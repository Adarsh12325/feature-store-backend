# .env.example
# ============================================================================
# Environment variable template for the Feature Store Backend.
#
# Instructions:
#   1. Copy this file to .env in the project root:
#        cp .env.example .env
#   2. Adjust values for your environment if needed.
#   3. Never commit the real .env file to version control.
#
# Docker Compose will automatically read .env from the project root and
# inject these variables into each service container at runtime.
# ============================================================================

# ── Redis Connection ──────────────────────────────────────────────────────────
# When running inside Docker Compose, REDIS_HOST must match the service name
# defined in docker-compose.yml (i.e., "redis"). For local development outside
# Docker, use "localhost".
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Optional: Set a Redis password if your Redis instance requires authentication.
# Leave blank (or omit) for passwordless connections (default for local dev).
# REDIS_PASSWORD=

# ── API Service ───────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Ingestion Pipeline Tuning ─────────────────────────────────────────────────
# INGESTION_BATCH_SIZE: Number of synthetic user records pushed per pipeline flush.
# Higher values increase throughput but consume more client memory per batch.
INGESTION_BATCH_SIZE=500

# INGESTION_INTERVAL_SEC: Sleep duration (seconds) between consecutive batches.
# Setting to 0 runs the pipeline as fast as possible; use with caution.
INGESTION_INTERVAL_SEC=1.0
